<%- include('../partials/header') %>

<main class="flex-grow flex items-center justify-center bg-surface pt-[100px] pb-12 px-4">
    <div class="w-full max-w-md bg-surface-container-lowest rounded-xl shadow-lg border border-outline-variant p-8">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-on-surface mb-2">Admin Login</h1>
            <p class="text-on-surface-variant">Please enter your credentials to continue.</p>
        </div>
        
        <form action="/login" method="POST" class="space-y-6">
            <div>
                <label class="block mb-2 text-sm font-bold text-on-surface text-left">Username</label>
                <input type="text" name="username" required class="w-full border border-outline-variant rounded-lg p-3 outline-none focus:border-primary-container text-left" placeholder="admin">
            </div>

            <div>
                <label class="block mb-2 text-sm font-bold text-on-surface text-left">Password</label>
                <input type="password" name="password" required class="w-full border border-outline-variant rounded-lg p-3 outline-none focus:border-primary-container text-left" placeholder="123456">
            </div>

            <button type="submit" class="w-full bg-primary-container text-on-primary hover:bg-opacity-90 transition-colors font-bold py-3 rounded-lg shadow-sm">
                Login
            </button>
        </form>
        
    </div>
</main>

<%- include('../partials/footer') %>